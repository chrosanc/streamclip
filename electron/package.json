{
  "name": "streamclip",
  "version": "1.0.0",
  "description": "Auto viral clipper — Opus Clip style for TikTok shorts",
  "main": "main.js",
  "scripts": {
    "start": "node_modules/electron/dist/electron.exe .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.streamclip.app",
    "productName": "StreamClip",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "**/*",
      "!dist-electron/**/*",
      "!node_modules/.cache/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/streamclip-backend",
        "to": "backend"
      },
      {
        "from": "ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "ffprobe.exe",
        "to": "ffprobe.exe"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  }
}
