{
  "name": "streamclip",
  "version": "1.0.0",
  "description": "Auto viral clipper — Opus Clip style for TikTok shorts",
  "main": "electron/main.js",
  "scripts": {
    "start": "node start.js",
    "make": "electron-forge make"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "streamclip",
        "executableName": "streamclip"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "streamclip"
          }
        }
      ]
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "electron": "^32.0.0"
  }
}
